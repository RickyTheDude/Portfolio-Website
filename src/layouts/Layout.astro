---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Ayan Mahata',
  description = 'My cozy corner on the interwebs!',
} = Astro.props;

const navLinks = [
  { label: 'HOME', href: '/' },
  { label: 'WORK', href: '/work' },
  { label: 'BLOG', href: '/blog' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Ayan Mahata" />
    <meta name="theme-color" content="#ffffff" id="theme-color-meta" />

    <!-- Anti-FOUC Dark Mode Script -->
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      }
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <!-- Custom Magic Cursor -->
    <div id="magic-cursor"></div>

    <!-- Navigation -->
    <nav class="site-nav" id="site-nav">
      <div class="nav-inner">
        <div class="nav-brand-group">
          <a href="/" class="nav-brand" id="nav-home">
            AYAN MAHATA
          </a>
          <div class="nav-socials">
            <a
              href="https://github.com/RickyTheDude"
              target="_blank"
              rel="noopener noreferrer"
              class="neo-social-btn"
              id="header-github"
              aria-label="GitHub Profile"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="social-icon"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
            </a>
            <a
              href="https://www.linkedin.com/in/ayan-mahata-5ba223239/"
              target="_blank"
              rel="noopener noreferrer"
              class="neo-social-btn"
              id="header-linkedin"
              aria-label="LinkedIn Profile"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="social-icon"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            </a>
          </div>
        </div>
        <ul class="nav-links" id="nav-links">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="neo-btn"
                id={`nav-${link.label.toLowerCase()}`}
              >
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <button
              class="neo-social-btn dark-toggle"
              id="dark-toggle"
              aria-label="Toggle dark mode"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="social-icon sun-icon hidden" id="theme-icon-sun"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="social-icon moon-icon" id="theme-icon-moon"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
            </button>
          </li>
        </ul>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="container-page main-wrapper" id="main-content">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer" id="site-footer">
      <div class="footer-inner">
        <span class="mono font-bold">&copy; {new Date().getFullYear()} AYAN MAHATA</span>
        <span class="mono font-light footer-tagline">
          <span>My cozy corner on the interwebs!</span>
          <button id="footer-contact-trigger" class="neo-btn font-bold cursor-none" style="padding: 0.25rem 0.5rem; font-size: 0.75rem; font-family: var(--font-mono); line-height: 1;">CONTACT ME</button>
        </span>

        <span class="mono font-bold">LAST UPDATED: {new Date().toLocaleDateString('en-US', { month: 'short', year: 'numeric' }).toUpperCase()}</span>
      </div>
    </footer>


    <!-- Contact Modal -->
    <dialog id="contact-modal" class="neo-modal-dialog">
      <div class="sticky-note-modal">
        <!-- Masking Tape -->
        <div class="sticky-tape"></div>
        <button id="close-modal-btn" class="modal-close-btn" aria-label="Close modal">&times;</button>
        
        <div class="sticky-modal-content font-mono">
          <div class="sticky-modal-header">
            <span class="sticky-date">SAY HELLO!</span>
          </div>
          
          <p class="sticky-modal-text">
            Have a cool project or just want to chat? Drop me a line or give me a call!
          </p>
          
          <div class="contact-details">
            <div class="contact-item">
              <span class="contact-label">EMAIL:</span>
              <div class="email-container neo-box">
                <a href="mailto:academicayan2022@gmail.com" class="email-link">academicayan2022@gmail.com</a>
                <button id="copy-email-btn" class="copy-btn" title="Copy email">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="copy-icon"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                  <span id="copy-text">COPY</span>
                </button>
              </div>
            </div>
            
            <div class="contact-item">
              <span class="contact-label">PHONE:</span>
              <div class="phone-container neo-box">
                <a href="tel:+917585912067" class="phone-link">+91 7585912067</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </dialog>

    <!-- Scroll Progress Line -->
    <div id="scroll-progress"></div>

    <script>
      // Enable custom cursor styles only if JS loads
      document.documentElement.classList.add('custom-cursor-active');

      const magicCursor = document.getElementById('magic-cursor');

      // Track mouse coordinates for the interactive dot matrix background and custom cursor
      const updateMousePosition = (e: MouseEvent) => {
        document.documentElement.style.setProperty('--mouse-x', `${e.clientX}px`);
        document.documentElement.style.setProperty('--mouse-y', `${e.clientY}px`);
        
        if (magicCursor) {
          // Use translation for highly performant following
          magicCursor.style.transform = `translate3d(${e.clientX}px, ${e.clientY}px, 0) translate(-50%, -50%) rotate(var(--cursor-rotate, 0deg))`;
        }
      };

      const updateTouchPosition = (e: TouchEvent) => {
        if (e.touches && e.touches[0]) {
          document.documentElement.style.setProperty('--mouse-x', `${e.touches[0].clientX}px`);
          document.documentElement.style.setProperty('--mouse-y', `${e.touches[0].clientY}px`);
        }
      };

      // Add listeners for mouse and touch interactions
      window.addEventListener('mousemove', updateMousePosition);
      window.addEventListener('touchmove', updateTouchPosition);

      // Scroll Progress Indicator & Header Transition
      const updateScrollProgress = () => {
        const currentScrollY = window.scrollY;
        const maxScrollY = document.documentElement.scrollHeight - window.innerHeight;
        
        // Calculate progress percentage
        const percent = maxScrollY > 0 ? (currentScrollY / maxScrollY) * 100 : 0;
        
        // Update width of the progress bar
        const progressLine = document.getElementById('scroll-progress');
        if (progressLine) {
          progressLine.style.width = `${percent}%`;
        }

        // Smooth header color transition at the bottom
        const nav = document.getElementById('site-nav');
        if (nav) {
          if (percent >= 99.5) { // reached the absolute bottom
            nav.classList.add('nav-at-bottom');
          } else {
            nav.classList.remove('nav-at-bottom');
          }
        }
      };

      window.addEventListener('scroll', updateScrollProgress, { passive: true });
      window.addEventListener('resize', updateScrollProgress, { passive: true });
      
      // Automatically update when page layout/height changes dynamically
      const resizeObserver = new ResizeObserver(() => {
        updateScrollProgress();
      });
      if (document.documentElement) {
        resizeObserver.observe(document.documentElement);
      }

      // Dynamic Neobrutalist Shadow Tracking
      const initDynamicShadows = () => {
        const tiles = document.querySelectorAll('.neo-box, .neo-panel');
        
        tiles.forEach((tile) => {
          const htmlTile = tile as HTMLElement;
          
          htmlTile.addEventListener('mousemove', (e) => {
            const rect = htmlTile.getBoundingClientRect();
            const mouseX = e.clientX;
            const mouseY = e.clientY;
            
            const centerX = rect.left + rect.width / 2;
            const centerY = rect.top + rect.height / 2;
            
            const dx = mouseX - centerX;
            const dy = mouseY - centerY;
            
            // Maximum shadow offset in pixels
            const maxOffset = 10;
            
            // Calculate shadow position (pushed away from cursor to act as light source)
            const shadowX = -((dx / (rect.width / 2)) * maxOffset);
            const shadowY = -((dy / (rect.height / 2)) * maxOffset);
            
            htmlTile.style.setProperty('--x-shadow', `${shadowX.toFixed(1)}px`);
            htmlTile.style.setProperty('--y-shadow', `${shadowY.toFixed(1)}px`);
          });
          
          htmlTile.addEventListener('mouseleave', () => {
            htmlTile.style.removeProperty('--x-shadow');
            htmlTile.style.removeProperty('--y-shadow');
          });
        });
      };

      // Initialize Magic Cursor Lens Effects
      const initLensEffect = () => {
        const cursor = document.getElementById('magic-cursor');
        if (!cursor) return;
        
        document.body.addEventListener('mouseover', (e) => {
          const target = e.target as HTMLElement;
          if (!target) return;

          // If hovering inside a button, turn into a selector shape
          if (target.closest('.neo-btn, .neo-social-btn, button')) {
            cursor.classList.remove('lens-active');
            cursor.classList.add('selector-active');
            return;
          } else {
            cursor.classList.remove('selector-active');
          }
          
          // Target all standard text elements + any div containing plain text metadata
          const isTextElement = target.closest('h1, h2, h3, h4, h5, h6, p, span, li, a, strong, em, .font-mono div, .footer-inner');
          
          if (isTextElement) {
            // Dynamically scale looking glass based on font size
            const style = window.getComputedStyle(isTextElement as Element);
            const fontSize = parseFloat(style.fontSize) || 16;
            
            // Refined ratio: 16px text -> 60px lens, 48px text -> 120px lens
            const lensSize = Math.min(Math.max(60, fontSize * 2.5), 150);
            
            cursor.style.setProperty('--lens-size', `${lensSize}px`);
            cursor.classList.add('lens-active');
          } else {
            cursor.classList.remove('lens-active');
          }
        });
      };

      // Contact Modal Logic
      const initContactModal = () => {
        const trigger = document.getElementById('footer-contact-trigger');
        const modal = document.getElementById('contact-modal') as HTMLDialogElement | null;
        const closeBtn = document.getElementById('close-modal-btn');
        const copyBtn = document.getElementById('copy-email-btn');
        const copyText = document.getElementById('copy-text');
        const emailLink = document.querySelector('.email-link') as HTMLAnchorElement | null;

        if (!modal || !trigger) return;

        trigger.addEventListener('click', () => {
          modal.showModal();
          if (magicCursor) modal.appendChild(magicCursor);
          document.body.style.overflow = 'hidden'; // prevent scrolling behind
        });

        const closeModal = () => {
          modal.close();
        };

        modal.addEventListener('close', () => {
          if (magicCursor) document.body.appendChild(magicCursor);
          document.body.style.overflow = '';
        });

        closeBtn?.addEventListener('click', closeModal);

        // Close on clicking outside the sticky note (the backdrop)
        modal.addEventListener('click', (e) => {
          const rect = modal.getBoundingClientRect();
          const isInDialog = (
            e.clientX >= rect.left &&
            e.clientX <= rect.right &&
            e.clientY >= rect.top &&
            e.clientY <= rect.bottom
          );
          const clickedOnStickyNote = (e.target as HTMLElement).closest('.sticky-note-modal');
          if (!isInDialog || !clickedOnStickyNote) {
            closeModal();
          }
        });

        // Copy Email logic
        copyBtn?.addEventListener('click', () => {
          if (!emailLink) return;
          const email = emailLink.textContent || 'academicayan2022@gmail.com';
          navigator.clipboard.writeText(email).then(() => {
            if (copyText) {
              copyText.textContent = 'COPIED!';
              setTimeout(() => {
                copyText.textContent = 'COPY';
              }, 2000);
            }
          }).catch(err => {
            console.error('Failed to copy email: ', err);
          });
        });
      };

      // Dark Mode Toggle Logic
      const initDarkModeToggle = () => {
        const toggleBtn = document.getElementById('dark-toggle');
        const sunIcon = document.getElementById('theme-icon-sun');
        const moonIcon = document.getElementById('theme-icon-moon');
        const metaThemeColor = document.getElementById('theme-color-meta');

        const updateUI = (isDark) => {
          if (isDark) {
            sunIcon?.classList.remove('hidden');
            moonIcon?.classList.add('hidden');
            if (metaThemeColor) metaThemeColor.setAttribute('content', '#1a1a1a');
          } else {
            sunIcon?.classList.add('hidden');
            moonIcon?.classList.remove('hidden');
            if (metaThemeColor) metaThemeColor.setAttribute('content', '#ffffff');
          }
        };

        // Initial sync with DOM state set by anti-FOUC script
        const isCurrentlyDark = document.documentElement.classList.contains('dark');
        updateUI(isCurrentlyDark);

        toggleBtn?.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          updateUI(isDark);
        });
      };

      // Run on initialization
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          initDynamicShadows();
          initLensEffect();
          initDarkModeToggle();
          initContactModal();
        });
      } else {
        initDynamicShadows();
        initLensEffect();
        initDarkModeToggle();
        initContactModal();
      }
    </script>
  </body>
</html>

<style>
  /* --- Navigation --- */
  .site-nav {
    background-color: var(--color-main);
    border-bottom: var(--border-width) solid var(--color-fg);
    padding: 1.25rem clamp(1.5rem, 5vw, 4rem);
    position: sticky;
    top: 0;
    z-index: 100;
    transition: background-color 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .site-nav.nav-at-bottom {
    background-color: var(--color-pink) !important;
    border-bottom-color: var(--color-pink) !important;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .nav-brand-group {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-socials {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .neo-social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    background-color: var(--color-main);
    border: var(--border-width) solid var(--color-fg);
    box-shadow: 3px 3px 0px 0px var(--box-shadow-color);
    color: var(--color-fg);
    transition: transform 0.15s ease, box-shadow 0.15s ease, background-color 0.25s ease;
  }

  .neo-social-btn:hover {
    transform: translate(3px, 3px);
    box-shadow: 0px 0px 0px 0px var(--box-shadow-color);
  }

  #header-github:hover {
    background-color: var(--color-fg);
    color: var(--color-main);
  }

  #dark-toggle {
    background-color: #ffc300 !important;
    color: #111111 !important;
    border-color: var(--color-fg) !important;
    box-shadow: 3px 3px 0px 0px var(--box-shadow-color) !important;
  }

  #dark-toggle:hover {
    background-color: #e0ab00 !important;
    transform: translate(3px, 3px);
    box-shadow: 0px 0px 0px 0px var(--box-shadow-color) !important;
  }

  #header-linkedin:hover {
    background-color: #74c0fc; /* Premium light blue */
    color: var(--color-fg);
  }

  .social-icon {
    display: block;
    width: 18px;
    height: 18px;
  }

  .social-icon.hidden {
    display: none !important;
  }

  .nav-brand {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 900;
    color: var(--color-fg);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    list-style: none;
    gap: 1rem;
    margin: 0;
    padding: 0;
  }

  .main-wrapper {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  /* --- Footer --- */
  .site-footer {
    background-color: var(--color-main);
    border-top: var(--border-width) solid var(--color-fg);
    padding: 2rem clamp(1.5rem, 5vw, 4rem);
    margin-top: 4rem;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: var(--container-max);
    margin: 0 auto;
    font-size: 0.875rem;
  }

  .footer-tagline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  /* --- Responsive --- */
  @media (max-width: 640px) {
    .nav-inner {
      flex-direction: column;
      gap: 1rem;
    }

    .footer-inner {
      flex-direction: column;
      gap: 1.25rem;
      text-align: center;
    }

    .footer-tagline {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.50rem;
    }
  }

  /* --- Contact Modal & Sticky Note --- */
  .neo-modal-dialog {
    border: none;
    background: transparent;
    padding: 0;
    max-width: none;
    max-height: none;
    overflow: visible;
    margin: auto;
  }

  .neo-modal-dialog::backdrop {
    background-color: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
  }

  .sticky-note-modal {
    position: relative;
    background-color: #fef08a; /* classic sticky note yellow */
    border: var(--border-width) solid var(--color-fg);
    box-shadow: 10px 10px 0 0 rgba(0, 0, 0, 0.3);
    padding: 3rem 2rem 2.5rem;
    width: 90vw;
    max-width: 420px;
    color: #111111;
    transform: rotate(-1deg);
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s ease;
  }

  .sticky-note-modal:hover {
    transform: rotate(0deg) scale(1.02);
    box-shadow: 14px 14px 0 0 rgba(0, 0, 0, 0.35);
  }

  /* Modal Masking Tape */
  .sticky-note-modal .sticky-tape {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%) rotate(1deg);
    width: 90px;
    height: 28px;
    background-color: rgba(255, 255, 255, 0.7);
    border: 1.5px solid rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(2px);
    z-index: 12;
    box-shadow: 1px 1px 2px rgba(0,0,0,0.15);
  }

  /* Close Button styled like a small pin or tag */
  .modal-close-btn {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: #ff7a59; /* terracotta red */
    color: #ffffff;
    border: 2px solid var(--color-fg);
    font-size: 1.25rem;
    font-weight: bold;
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: none; /* custom cursor is active */
    box-shadow: 2px 2px 0px 0px var(--box-shadow-color);
    transition: transform 0.1s ease, box-shadow 0.1s ease;
  }

  .modal-close-btn:hover {
    transform: translate(2px, 2px);
    box-shadow: 0px 0px 0px 0px var(--box-shadow-color);
  }

  .sticky-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px dashed rgba(0,0,0,0.2);
  }

  .sticky-date {
    font-size: 0.85rem;
    font-weight: 800;
  }

  .sticky-mood {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    background-color: rgba(255,255,255,0.4);
    border: 1.5px solid rgba(0,0,0,0.4);
    padding: 0.15em 0.5em;
  }

  .sticky-modal-text {
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .contact-label {
    font-size: 0.75rem;
    font-weight: 800;
    color: rgba(0, 0, 0, 0.6);
  }

  .email-container,
  .phone-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background-color: #ffffff;
    padding: 0.5rem 0.75rem;
    font-size: 0.85rem;
    border: 2px solid var(--color-fg);
  }

  .email-link,
  .phone-link {
    color: #111111;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .copy-btn {

---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import '../../styles/global.css';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const [featured, ...rest] = allPosts;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  }).toUpperCase();
}

function readingTime(body: string) {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.round(words / 200));
}

// Cycle through accent colors for grid cards
const ACCENTS = ['var(--color-yellow)', 'var(--color-cyan)', 'var(--color-pink)'];
---

<Layout
  title="Blog — Ayan Mahata"
  description="Thoughts, writeups, and experiments on software development, cybersecurity, consumer electronics, and design."
>
  <div class="page-sheet">

    <!-- ═══════ HEADER ═══════ -->
    <header class="blog-header">
      <div>
        <p class="blog-eyebrow font-mono">BLOG</p>
        <h1 class="blog-heading">Writing.</h1>
      </div>
      <p class="blog-sub font-mono">
        {allPosts.length} post{allPosts.length !== 1 ? 's' : ''} curated by yours truly.
      </p>
    </header>

    {allPosts.length === 0 ? (
      <p class="empty font-mono">// no posts yet.</p>
    ) : (
      <div class="bento">

        <!-- ═══════ FEATURED ═══════ -->
        {featured && (
          <a
            href={`/blog/${featured.id}`}
            class="bento-featured"
            id={`post-${featured.id}`}
          >
            <!-- corner label -->
            <span class="feat-label font-mono">LATEST</span>

            <!-- big post number -->
            <span class="feat-num font-mono" aria-hidden="true">01</span>

            <!-- content -->
            <div class="feat-body">
              <div class="feat-meta font-mono">
                <span>{formatDate(featured.data.date)}</span>
                <span class="feat-dot">·</span>
                <span>{readingTime(featured.body ?? '')} min read</span>
              </div>
              <h2 class="feat-title">{featured.data.title}</h2>
              <p class="feat-desc font-mono">{featured.data.description}</p>
            </div>

            <!-- tags -->
            {featured.data.tags.length > 0 && (
              <div class="feat-tags">
                {featured.data.tags.map(tag => (
                  <span class="neo-tag">{tag}</span>
                ))}
              </div>
            )}

            <!-- arrow -->
            <span class="feat-arrow font-mono" aria-hidden="true">↗</span>
          </a>
        )}

        <!-- ═══════ GRID ═══════ -->
        {rest.length > 0 && (
          <div class="bento-grid">
            {rest.map((post, i) => {
              const accent = ACCENTS[(i + 1) % ACCENTS.length];
              const mins = readingTime(post.body ?? '');
              return (
                <a
                  href={`/blog/${post.id}`}
                  class="bento-card"
                  id={`post-${post.id}`}
                  style={`--card-accent: ${accent};`}
                >
                  <!-- top color bar -->
                  <div class="card-bar"></div>

                  <!-- body -->
                  <div class="card-body">
                    <div class="card-meta font-mono">
                      <span>{formatDate(post.data.date)}</span>
                      <span class="card-mins">{mins} min</span>
                    </div>
                    <h2 class="card-title">{post.data.title}</h2>
                    <p class="card-desc font-mono">{post.data.description}</p>
                  </div>

                  <!-- footer -->
                  <div class="card-footer">
                    {post.data.tags.slice(0, 2).map(tag => (
                      <span class="neo-tag">{tag}</span>
                    ))}
                    <span class="card-arrow font-mono" aria-hidden="true">→</span>
                  </div>
                </a>
              );
            })}
          </div>
        )}

      </div>
    )}

  </div>
</Layout>

<style>
  /* ── Page sheet ── */
  .page-sheet {
    background: #ffffff;
    border: 3px solid var(--color-fg);
    box-shadow: 8px 8px 0 0 var(--color-fg);
    padding: 3rem clamp(1.5rem, 5vw, 3.5rem) 3.5rem;
    position: relative;
    z-index: 1;
  }

  /* ── Header ── */
  .blog-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .blog-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #aaa;
    margin: 0 0 0.5rem;
  }

  .blog-heading {
    font-size: clamp(3.5rem, 10vw, 6.5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.9;
    margin: 0;
    width: fit-content;
  }

  .blog-sub {
    font-size: 0.82rem;
    font-weight: 400;
    color: #777;
    line-height: 1.7;
    margin: 0;
    text-align: right;
  }

  /* ── Bento wrapper ── */
  .bento {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ── Featured card ── */
  .bento-featured {
    display: grid;
    grid-template-rows: auto 1fr auto;
    position: relative;
    background-color: var(--color-yellow);
    border: 3px solid var(--color-fg);
    box-shadow: 6px 6px 0 0 var(--color-fg);
    padding: 2rem 2rem 1.75rem;
    text-decoration: none;
    color: var(--color-fg);
    overflow: hidden;
    min-height: 300px;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .bento-featured:hover {
    transform: translate(3px, 3px);
    box-shadow: 3px 3px 0 0 var(--color-fg);
  }

  /* big watermark number */
  .feat-num {
    position: absolute;
    right: -0.1em;
    bottom: -0.25em;
    font-size: clamp(8rem, 20vw, 14rem);
    font-weight: 900;
    line-height: 1;
    color: rgba(0,0,0,0.07);
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.05em;
  }

  .feat-label {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    background: var(--color-fg);
    color: var(--color-yellow);
    padding: 0.2em 0.75em;
    margin-bottom: 1.5rem;
    width: fit-content;
  }

  .feat-body {
    position: relative;
    z-index: 1;
  }

  .feat-meta {
    font-size: 0.72rem;
    font-weight: 700;
    color: rgba(0,0,0,0.5);
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .feat-dot { color: rgba(0,0,0,0.2); }

  .feat-title {
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 0.75rem;
    width: 100%;
    max-width: none;
    max-width: 22ch;
    text-transform: none;
  }

  .feat-desc {
    font-size: 0.85rem;
    color: rgba(0,0,0,0.6);
    line-height: 1.65;
    margin: 0;
    max-width: 48ch;
    font-weight: 400;
  }

  .feat-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
    position: relative;
    z-index: 1;
  }

  .feat-arrow {
    position: absolute;
    top: 1.75rem;
    right: 2rem;
    font-size: 1.5rem;
    font-weight: 900;
    opacity: 0.3;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .bento-featured:hover .feat-arrow {
    opacity: 1;
    transform: translate(3px, -3px);
  }

  /* ── Grid ── */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  /* ── Grid card ── */
  .bento-card {
    display: flex;
    flex-direction: column;
    border: 3px solid var(--color-fg);
    box-shadow: 5px 5px 0 0 var(--color-fg);
    background: #fff;
    text-decoration: none;
    color: var(--color-fg);
    overflow: hidden;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .bento-card:hover {
    transform: translate(3px, 3px);
    box-shadow: 2px 2px 0 0 var(--color-fg);
  }

  .card-bar {
    height: 8px;
    background-color: var(--card-accent);
    flex-shrink: 0;
  }

  .card-body {
    flex: 1;
    padding: 1.5rem 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.68rem;
    font-weight: 700;
    color: #aaa;
  }

  .card-mins {
    background-color: var(--card-accent);
    border: 1.5px solid var(--color-fg);
    padding: 0.05em 0.5em;
    color: var(--color-fg);
    font-size: 0.65rem;
  }

  .card-title {
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    font-weight: 900;
    letter-spacing: -0.025em;
    line-height: 1.2;
    margin: 0;
    width: 100%;
    max-width: none;
    text-transform: none;
  }

  .card-desc {
    font-size: 0.78rem;
    color: #777;
    line-height: 1.6;
    margin: 0;
    font-weight: 400;
    /* clamp to 3 lines */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 1.5rem;
    border-top: 2px solid #f0f0f0;
  }

  .card-arrow {
    margin-left: auto;
    font-size: 1rem;
    font-weight: 700;
    color: #ccc;
    transition: color 0.15s ease, transform 0.15s ease;
  }

  .bento-card:hover .card-arrow {
    color: var(--color-fg);
    transform: translateX(3px);
  }

  /* ── Empty ── */
  .empty {
    font-size: 0.9rem;
    color: #aaa;
    padding: 4rem 0;
  }

  /* ── Mobile ── */
  @media (max-width: 600px) {
    .blog-sub { text-align: left; }
    .bento-grid { grid-template-columns: 1fr; }
    .feat-num { font-size: 7rem; }
  }
</style>

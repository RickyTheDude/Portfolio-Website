---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

function readingTime(body: string) {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.round(words / 200));
}

const mins = readingTime(post.body ?? '');
---

<Layout
  title={`${post.data.title} — Ayan Mahata`}
  description={post.data.description}
>
  <div class="page-sheet">

    <!-- ═══════ HERO HEADER ═══════ -->
    <div class="post-hero">
      <!-- back link -->
      <a href="/blog" class="post-back font-mono" id="back-to-blog">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        BLOG
      </a>

      <!-- meta -->
      <div class="post-hero-meta font-mono">
        <span class="post-hero-date">{formatDate(post.data.date)}</span>
        <span class="post-hero-sep">·</span>
        <span class="post-hero-mins">{mins} min read</span>
      </div>

      <!-- title -->
      <h1 class="post-hero-title">{post.data.title}</h1>

      <!-- tags row -->
      {post.data.tags.length > 0 && (
        <div class="post-hero-tags">
          {post.data.tags.map(tag => (
            <span class="neo-tag">{tag}</span>
          ))}
        </div>
      )}
    </div>

    <!-- ═══════ DESCRIPTION BRIDGE ═══════ -->
    <div class="post-bridge">
      <p class="post-desc font-mono">{post.data.description}</p>
      <div class="post-bridge-line"></div>
    </div>

    <!-- ═══════ ARTICLE ═══════ -->
    <article class="prose-blog" id="article-body">
      <Content />
    </article>

    <!-- ═══════ FOOTER ═══════ -->
    <div class="post-footer">
      <a href="/blog" class="neo-btn font-mono font-bold px-5 py-2 flex items-center gap-2 w-fit" id="bottom-back-to-blog">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        ALL POSTS
      </a>
    </div>

  </div>
</Layout>

<style>
  /* ── Page sheet ── */
  .page-sheet {
    background: var(--color-main);
    border: 3px solid var(--color-fg);
    box-shadow: 8px 8px 0 0 var(--color-fg);
    padding: 0;
    position: relative;
    z-index: 1;
    overflow: hidden;
  }

  /* ── Hero ── */
  .post-hero {
    padding: 2.5rem clamp(1.5rem, 5vw, 3.5rem) 2.5rem;
    background-color: var(--color-cyan);
    border-bottom: 3px solid var(--color-fg);
    position: relative;
    overflow: hidden;
    color: #111;
  }

  /* decorative oversized letter */
  .post-hero::after {
    content: '//';
    position: absolute;
    right: -0.05em;
    bottom: -0.3em;
    font-family: var(--font-mono);
    font-size: clamp(6rem, 18vw, 12rem);
    font-weight: 900;
    color: rgba(0,0,0,0.06);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  .post-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: rgba(0,0,0,0.5);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.15s ease;
  }

  .post-back:hover { color: #111; }

  .post-hero-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 700;
    color: rgba(0,0,0,0.45);
    margin-bottom: 1rem;
  }

  .post-hero-sep { color: rgba(0,0,0,0.2); }

  .post-hero-title {
    font-size: clamp(2rem, 6vw, 3.75rem);
    font-weight: 900;
    letter-spacing: -0.035em;
    line-height: 1.05;
    margin: 0 0 1.5rem;
    width: 100%;
    max-width: none;
    max-width: 22ch;
    text-transform: none;
    position: relative;
    z-index: 1;
  }

  .post-hero-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    position: relative;
    z-index: 1;
  }

  /* ── Description bridge ── */
  .post-bridge {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: center;
    padding: 2rem clamp(1.5rem, 5vw, 3.5rem);
    border-bottom: 3px solid var(--color-fg);
    margin-bottom: 0;
  }

  .post-desc {
    font-size: 0.92rem;
    color: var(--color-fg);
    opacity: 0.8;
    line-height: 1.75;
    margin: 0;
    max-width: 58ch;
    font-weight: 400;
  }

  .post-bridge-line {
    width: 48px;
    height: 3px;
    background-color: var(--color-yellow);
  }

  /* ── Prose ── */
  .prose-blog {
    font-family: var(--font-mono);
    font-size: 0.93rem;
    line-height: 1.9;
    color: var(--color-fg);
    max-width: 68ch;
    padding: 3rem clamp(1.5rem, 5vw, 3.5rem) 0;
  }

  .prose-blog :global(h2) {
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 2.5vw, 1.55rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin-top: 3rem;
    margin-bottom: 1rem;
    width: 100%;
    max-width: none;
    padding-bottom: 0.5rem;
    border-bottom: 3px solid var(--color-fg);
  }

  .prose-blog :global(h3) {
    font-family: var(--font-heading);
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 800;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    width: 100%;
    max-width: none;
  }

  .prose-blog :global(p) {
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
    font-weight: 400;
  }

  .prose-blog :global(strong) { font-weight: 700; }
  .prose-blog :global(em) { font-style: italic; }

  .prose-blog :global(a) {
    color: var(--color-fg);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-yellow);
    transition: text-decoration-color 0.2s ease;
  }

  .prose-blog :global(a:hover) {
    text-decoration-color: var(--color-pink);
  }

  .prose-blog :global(blockquote) {
    border-left: 4px solid var(--color-fg);
    margin: 2rem 0;
    padding: 0.75rem 1.5rem;
    background-color: var(--color-pink);
    color: #111;
  }

  .prose-blog :global(blockquote p) { margin: 0; }

  .prose-blog :global(ul),
  .prose-blog :global(ol) {
    margin: 1.25rem 0;
    padding-left: 1.75rem;
  }

  .prose-blog :global(li) { margin-bottom: 0.5rem; }
  .prose-blog :global(ul li) { list-style-type: '▸  '; }
  .prose-blog :global(ol li) { list-style-type: decimal; }

  .prose-blog :global(pre) {
    background-color: var(--color-fg);
    color: #f8f8f2;
    border: 3px solid var(--color-fg);
    padding: 1.5rem;
    overflow-x: auto;
    margin: 2rem 0;
    font-size: 0.82rem;
    line-height: 1.7;
    box-shadow: 5px 5px 0 0 var(--box-shadow-color);
  }

  .prose-blog :global(code) { font-family: var(--font-mono); }

  .prose-blog :global(p code),
  .prose-blog :global(li code) {
    background-color: var(--color-bg);
    border: 1.5px solid var(--color-fg);
    padding: 0.1em 0.4em;
    font-size: 0.875em;
  }

  .prose-blog :global(hr) {
    border: none;
    border-top: 3px solid var(--color-fg);
    margin: 3rem 0;
  }

  .prose-blog :global(img) {
    max-width: 100%;
    border: 3px solid var(--color-fg);
    box-shadow: 5px 5px 0 0 var(--box-shadow-color);
    margin: 2rem 0;
  }

  /* ── Footer ── */
  .post-footer {
    margin-top: 4rem;
    padding: 2rem clamp(1.5rem, 5vw, 3.5rem) 3rem;
    border-top: 3px solid var(--color-fg);
  }
</style>

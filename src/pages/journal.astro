---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import '../styles/global.css';

const entries = await getCollection('journal', ({ data }) => !data.draft);
entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Render all entries upfront
const rendered = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

function formatShort(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  }).toUpperCase();
}
---

<Layout
  title="Journal — Ayan Mahata"
  description="A running log of thoughts, small wins, things I'm learning, and whatever else is on my mind."
>
  <div class="page-sheet">

    <!-- ═══════ HEADER ═══════ -->
    <div class="journal-header">
      <div>
        <p class="journal-eyebrow font-mono">JOURNAL</p>
        <h1 class="journal-title">Field Notes.</h1>
      </div>
      <p class="journal-sub font-mono">
        A running log.<br/>
        Updated whenever.
      </p>
    </div>

    <!-- ═══════ ENTRIES ═══════ -->
    {rendered.length === 0 ? (
      <p class="journal-empty font-mono">// nothing yet. check back soon.</p>
    ) : (
      <div class="journal-feed">
        {rendered.map(({ entry, Content }, i) => (
          <div class="journal-entry" id={`entry-${entry.id}`}>

            <!-- date + mood bar -->
            <div class="entry-header">
              <div class="entry-date-block">
                <span class="entry-index font-mono">#{String(rendered.length - i).padStart(2, '0')}</span>
                <time class="entry-date font-mono" datetime={entry.data.date.toISOString()}>
                  {formatDate(entry.data.date)}
                </time>
              </div>
              {entry.data.mood && (
                <span class="entry-mood font-mono">{entry.data.mood}</span>
              )}
            </div>

            <!-- body -->
            <div class="entry-body journal-prose">
              <Content />
            </div>

          </div>
        ))}
      </div>
    )}

    <!-- ═══════ BACK ═══════ -->
    <div class="journal-footer">
      <a href="/" class="neo-btn font-mono font-bold px-5 py-2 flex items-center gap-2 w-fit" id="journal-home-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        HOME
      </a>
    </div>

  </div>
</Layout>

<style>
  /* ── Sheet ── */
  .page-sheet {
    background: var(--color-main);
    border: 3px solid var(--color-fg);
    box-shadow: 8px 8px 0 0 var(--color-fg);
    position: relative;
    z-index: 1;
    overflow: hidden;
  }

  /* ── Header ── */
  .journal-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    flex-wrap: wrap;
    padding: 3rem clamp(1.5rem, 5vw, 3.5rem) 2.5rem;
    border-bottom: 3px solid var(--color-fg);
    background-color: var(--color-pink); /* sage green */
    color: var(--color-fg);
  }

  .journal-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--color-fg);
    opacity: 0.6;
    margin: 0 0 0.5rem;
  }

  .journal-title {
    font-size: clamp(3rem, 9vw, 6rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.9;
    margin: 0;
    width: fit-content;
  }

  .journal-sub {
    font-size: 0.8rem;
    color: var(--color-fg);
    opacity: 0.7;
    line-height: 1.7;
    margin: 0;
    text-align: right;
    font-weight: 400;
  }

  /* ── Feed ── */
  .journal-feed {
    display: flex;
    flex-direction: column;
  }

  /* ── Entry ── */
  .journal-entry {
    padding: 3rem clamp(1.5rem, 5vw, 3.5rem);
    border-bottom: 2px solid var(--color-fg);
    opacity: 0.95;
    position: relative;
    scroll-margin-top: 140px; /* clears the fixed navbar when jumping to an anchor */
  }

  /* subtle left accent bar */
  .journal-entry::before {
    content: '';
    position: absolute;
    left: 0;
    top: 3rem;
    bottom: 3rem;
    width: 3px;
    background-color: var(--color-pink);
  }

  .entry-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .entry-date-block {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .entry-index {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--color-fg);
    opacity: 0.4;
  }

  .entry-date {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-fg);
    letter-spacing: 0.02em;
  }

  .entry-mood {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background-color: var(--color-cyan);
    border: 1.5px solid var(--color-fg);
    padding: 0.2em 0.7em;
    color: #111;
  }

  /* ── Journal prose ── */
  .journal-prose {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.9;
    color: var(--color-fg);
    max-width: 66ch;
  }

  .journal-prose :global(p) {
    margin: 0 0 1.1rem;
    font-weight: 400;
  }

  .journal-prose :global(p:last-child) {
    margin-bottom: 0;
  }

  .journal-prose :global(strong) { font-weight: 700; color: var(--color-fg); }
  .journal-prose :global(em) { font-style: italic; }

  .journal-prose :global(a) {
    color: var(--color-fg);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-yellow);
  }

  .journal-prose :global(ul),
  .journal-prose :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .journal-prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .journal-prose :global(ul li) { list-style-type: '–  '; }
  .journal-prose :global(ol li) { list-style-type: decimal; }

  .journal-prose :global(blockquote) {
    border-left: 3px solid var(--color-fg);
    padding-left: 1rem;
    color: var(--color-fg);
    opacity: 0.7;
    font-style: italic;
    margin: 1.25rem 0;
  }

  .journal-prose :global(code) {
    font-family: var(--font-mono);
    background: var(--color-bg);
    border: 1.5px solid var(--color-fg);
    padding: 0.1em 0.4em;
    font-size: 0.875em;
  }

  /* ── Empty ── */
  .journal-empty {
    font-size: 0.9rem;
    color: var(--color-fg);
    opacity: 0.5;
    padding: 4rem clamp(1.5rem, 5vw, 3.5rem);
  }

  /* ── Footer ── */
  .journal-footer {
    padding: 2rem clamp(1.5rem, 5vw, 3.5rem) 3rem;
    border-top: 3px solid var(--color-fg);
  }

  /* ── Mobile ── */
  @media (max-width: 600px) {
    .journal-sub { text-align: left; }
    .entry-header { flex-direction: column; align-items: flex-start; }
  }
</style>
